const links = linksText
  .trim()
  .split("\n")
  .map((v) => v.replace(/^- /, "").trim())
  .filter(Boolean);

function getHostname(url: string) {
  return new URL(url).hostname.toLowerCase();
}

function getFaviconUrl(url: string) {
  return `https://www.google.com/s2/favicons?domain=${getHostname(url)}&sz=32`;
}

function compareHostnamesFromRight(a: string, b: string) {
  const partsA = a.split(".").reverse();
  const partsB = b.split(".").reverse();
  const len = Math.max(partsA.length, partsB.length);

  for (let i = 0; i < len; i++) {
    const partA = partsA[i] ?? "";
    const partB = partsB[i] ?? "";

    const diff = partA.localeCompare(partB);
    if (diff !== 0) return diff;
  }

  return 0;
}

const sortedLinks = [...new Set(links)].sort((a, b) => {
  return compareHostnamesFromRight(getHostname(a), getHostname(b));
});
---

<PageLayout meta={{ title: "links" }}>
  <div
    class="prose-sm prose-cactus prose-headings:pl-4 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
  >
    <h1 class="title">webring</h1>

    <ul>
      {sortedLinks.map((link) => (
        <li>
          <a href={link} target="_blank" rel="noopener noreferrer">
            <span
              class="inline-block w-4 h-4 mr-0 align-[-3px] bg-center bg-no-repeat bg-contain"
              style={`background-image: url('${getFaviconUrl(link)}');`}
              aria-hidden="true"
            ></span>
            {link}
          </a>
        </li>
      ))}
    </ul>
  </div>
</PageLayout>

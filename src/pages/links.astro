- https://poyo.me/
- https://yuinoid.neocities.org/
- https://kusaremkn.com/
- https://www.yude.jp/
`;

const links = linksText
  .trim()
  .split("\n")
  .map((v) => v.replace(/^- /, "").trim())
  .filter(Boolean);

function getHostname(url: string) {
  return new URL(url).hostname.toLowerCase();
}

function getTld(url: string) {
  const parts = getHostname(url).split(".");
  return parts[parts.length - 1] ?? "";
}

const sortedLinks = [...new Set(links)].sort((a, b) => {
  const tldA = getTld(a);
  const tldB = getTld(b);

  if (tldA !== tldB) {
    return tldA.localeCompare(tldB);
  }

  return getHostname(a).localeCompare(getHostname(b));
});
---

<PageLayout meta={{ title: "links" }}>
  <div
    class="prose-sm prose-cactus prose-headings:pl-4 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
  >
    <h1 class="title">links</h1>

    <ul>
      {sortedLinks.map((link) => (
        <li>
          <a href={link}>{link}</a>
        </li>
      ))}
    </ul>
  </div>
</PageLayout>
---
import ArrowCard from "@/components/ArrowCard.astro";
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { type CollectionEntry, getCollection } from "astro:content";

// Posts
const MAX_POSTS = 5;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];
---

<PageLayout meta={{ title: "Home" }}>
	<div
		class="prose-sm prose-cactus prose-headings:pl-4 prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-accent prose-headings:before:content-['#'] prose-th:before:content-none"
	>
		<h1 class="title ">Home</h1>

		<div class="w-[80%] mx-auto flex flex-col sm:flex-row items-center sm:justify-center sm:h-[20vh] gap-2 sm:max-w-3xl mx-auto">

		<!-- 左：QRコード -->
		<div class="flex-[3] flex justify-center w-full">
			<img
			src="/qrcode-186.png"
			alt="QR Code"
			class="w-[60%] sm:w-[70%] max-h-full"
			/>
		</div>

		<!-- 右：アクセスカウンタ -->
		<div class="flex-[6] flex justify-center w-full">
			<img
			class="w-[95%] sm:w-auto max-h-full"
			src="https://count.getloli.com/@dokudamibox.net?name=dokudamibox.net&theme=green&padding=7&offset=0&align=top&scale=1&pixelated=1&darkmode=0"
			alt="Access Counter"
			/>
		</div>

		</div>

		{/* About This Blog セクション */}
		<section aria-label="About this blog" className="mt-16">

			<div class="flex flex-col sm:flex-row items-start sm:items-center gap-y-2 sm:hidden">
			<h2 class="font-semibold text-black dark:text-white">Information</h2>
			<ul>
				<li>
				<a href="/about" class="text-accent underline font-bold">About</a> ... dokudami について
				</li>
				<li>
				<a href="/posts" class="text-accent underline font-bold">Posts</a> ... 活動報告
				</li>
			</ul>
			</div>

			<!-- その時が来たらコメントアウトを外す -->
			<section aria-label="Blog post list" class="mt-16">
				<div class="flex flex-wrap items-center justify-between gap-y-2">
					<h2 class="font-semibold text-black dark:text-white">Latest Posts</h2>
					<a href="/posts" class="underline"> See all posts </a>
				</div>
				<div class="space-y-4" role="list">
					{
						allPostsByDate.map((p) => (
							<div class="not-prose">
								<ArrowCard post={p} />
							</div>
						))
					}
				</div>
			</section>
		</section>
	</div></PageLayout
>
